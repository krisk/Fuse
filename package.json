{
  "name": "fuse.js",
  "author": {
    "name": "Kiro Risk",
    "email": "kirollos@gmail.com",
    "url": "http://kiro.me"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/krisk"
  },
  "type": "module",
  "main": "./dist/fuse.cjs",
  "module": "./dist/fuse.mjs",
  "unpkg": "./dist/fuse.mjs",
  "jsdelivr": "./dist/fuse.mjs",
  "types": "./dist/fuse.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/fuse.d.ts",
        "default": "./dist/fuse.mjs"
      },
      "require": {
        "types": "./dist/fuse.d.cts",
        "default": "./dist/fuse.cjs"
      }
    },
    "./min": {
      "import": {
        "types": "./dist/fuse.d.ts",
        "default": "./dist/fuse.min.mjs"
      },
      "require": {
        "types": "./dist/fuse.d.cts",
        "default": "./dist/fuse.min.cjs"
      }
    },
    "./basic": {
      "import": {
        "types": "./dist/fuse.d.ts",
        "default": "./dist/fuse.basic.mjs"
      },
      "require": {
        "types": "./dist/fuse.d.cts",
        "default": "./dist/fuse.basic.cjs"
      }
    },
    "./min-basic": {
      "import": {
        "types": "./dist/fuse.d.ts",
        "default": "./dist/fuse.basic.min.mjs"
      },
      "require": {
        "types": "./dist/fuse.d.cts",
        "default": "./dist/fuse.basic.min.cjs"
      }
    },
    "./worker": {
      "import": {
        "types": "./dist/fuse-worker.d.ts",
        "default": "./dist/fuse-worker.mjs"
      },
      "require": {
        "types": "./dist/fuse-worker.d.cts",
        "default": "./dist/fuse-worker.cjs"
      }
    },
    "./worker-script": {
      "types": "./dist/fuse.worker.d.ts",
      "import": "./dist/fuse.worker.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "version": "7.5.0",
  "description": "Lightweight fuzzy-search",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/krisk/Fuse.git"
  },
  "homepage": "http://fusejs.io",
  "keywords": [
    "fuzzy",
    "search",
    "bitap"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "dev:cjs": "tsdown --watch",
    "build": "rm -rf dist && tsdown",
    "test": "vitest run",
    "typecheck": "tsc -p src/tsconfig.json --noEmit",
    "lint": "eslint src test",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.{js,ts}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.{js,ts}\"",
    "bench": "npm run build && npm run bench:search && npm run bench:index",
    "bench:search": "node bench/search.mjs",
    "bench:index": "node bench/index-creation.mjs",
    "bench:extended": "node bench/extended.mjs",
    "bench:tokens": "node bench/token-search.mjs",
    "bench:workers": "node bench/parallel-workers.mjs",
    "release": "./scripts/release.sh",
    "docs:bump": "node ./scripts/bump-docs.cjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:release": "./scripts/deploy-docs.sh",
    "prepare": "husky install"
  },
  "standard-version": {
    "scripts": {
      "postbump": "npm run build && npm run lint && npm run test 2>/dev/null",
      "precommit": "git add dist/*.cjs dist/*.mjs dist/*.d.ts dist/*.d.cts"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "esbuild": "^0.25.0",
    "fast-uri": "^3.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.4.2",
    "@commitlint/config-conventional": "^17.4.2",
    "@monaco-editor/loader": "^1.3.2",
    "@sapphire/stopwatch": "^1.5.0",
    "@sapphire/utilities": "^3.11.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^8.0.3",
    "monaco-editor": "^0.34.1",
    "prettier": "^3.8.3",
    "replace-in-file": "^6.3.5",
    "standard-version": "^9.5.0",
    "tsdown": "0.22.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.9",
    "vue": "^3.5.33"
  },
  "engines": {
    "node": ">=10"
  }
}
