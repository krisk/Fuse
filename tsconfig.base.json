{
  "compilerOptions": {
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "target": "es2020",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "declaration": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  }
}
